generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model NewsArticle {
  id          Int      @id @default(autoincrement())
  externalId  String   @unique
  title       String
  content     String?
  summary     String?
  url         String
  imageUrl    String?
  publishedAt DateTime?
  scrapedAt   DateTime @default(now())

  // Category from news API (finance, world, business, politics)
  categorySlug String?
  category     NewsCategory? @relation(fields: [categorySlug], references: [slug])

  // AI enrichment
  sentiment    String?       // BULLISH, BEARISH, NEUTRAL
  sentimentScore Float?      // -1 to 1
  locationName String?
  latitude     Float?
  longitude    Float?
  isConflict   Boolean @default(false)

  recommendations StockRecommendation[]
  aiLogs          AiAnalysisLog[]
  analyzed        Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categorySlug])
  @@index([analyzed])
  @@index([scrapedAt])
  @@index([latitude, longitude])
  @@index([isConflict, scrapedAt])
}

model NewsCategory {
  slug        String @id
  name        String
  description String?
  color       String?
  icon        String?
  articles    NewsArticle[]
}

model StockRecommendation {
  id         Int    @id @default(autoincrement())
  articleId  Int
  article    NewsArticle @relation(fields: [articleId], references: [id])
  symbol     String
  action     String   // BUY, SELL, HOLD, WATCH
  confidence Float    // 0-1
  reason     String?

  createdAt DateTime @default(now())

  @@index([symbol])
  @@index([articleId])
  @@index([createdAt])
  @@index([symbol, createdAt])
}

model StockQuote {
  id              Int      @id @default(autoincrement())
  symbol          String   @unique
  name            String?
  price           Float
  change          Float?
  changePercent   Float?
  volume          BigInt?
  marketCap       Float?
  dayHigh         Float?
  dayLow          Float?
  previousClose   Float?

  updatedAt DateTime @updatedAt
}

model TrackedStock {
  id        Int      @id @default(autoincrement())
  symbol    String   @unique
  name      String?
  source    String   @default("default") // default, ai-recommended
  addedAt   DateTime @default(now())

  @@index([source])
}

// ── Audit Models ──

model ScrapeRun {
  id           Int      @id @default(autoincrement())
  startedAt    DateTime @default(now())
  finishedAt   DateTime?
  status       String   @default("running") // running, success, error
  itemsFetched Int      @default(0)
  itemsNew     Int      @default(0)
  itemsSkipped Int      @default(0)
  itemsFailed  Int      @default(0)
  errorMessage String?
  durationMs   Int?
}

model AiAnalysisLog {
  id               Int      @id @default(autoincrement())
  articleId        Int
  article          NewsArticle @relation(fields: [articleId], references: [id])
  model            String?
  provider         String?
  rawResponse      String?
  parsedResult     String?
  promptTokens     Int?
  completionTokens Int?
  totalTokens      Int?
  startedAt        DateTime @default(now())
  durationMs       Int?
  status           String   // success, parse_error, api_error
  errorMessage     String?
  categorySlug     String?
  sentimentLabel   String?
  sentimentScore   Float?

  @@index([articleId])
  @@index([status])
}

model UserSession {
  id            Int      @id @default(autoincrement())
  userId        Int?
  user          User?    @relation("userSessions", fields: [userId], references: [id], onDelete: Cascade)
  walletAddress String
  chainId       Int?
  eventType     String   // connect, disconnect
  userAgent     String?
  createdAt     DateTime @default(now())

  @@index([walletAddress])
  @@index([userId])
}

model TradeOrder {
  id              Int      @id @default(autoincrement())
  userId          Int?
  user            User?    @relation("userTrades", fields: [userId], references: [id], onDelete: Cascade)
  walletAddress   String
  coin            String
  side            String   // buy, sell
  orderType       String   // market, limit
  size            Float
  price           Float?
  leverage        Int      @default(1)
  midPrice        Float?
  notionalValue   Float?
  marginRequired  Float?
  status          String   @default("demo") // demo, submitted, filled
  sourceArticleId Int?
  createdAt       DateTime @default(now())

  @@index([walletAddress])
  @@index([createdAt])
  @@index([userId])
}

// ── Pro Trading Features (v0.7.0) ──

model EconomicEvent {
  id         Int      @id @default(autoincrement())
  externalId String   @unique
  event      String
  country    String
  date       DateTime
  impact     String   // high, medium, low
  actual     String?
  previous   String?
  estimate   String?
  released   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([date])
  @@index([country])
  @@index([impact])
  @@index([released, date])
}

model Alert {
  id        Int      @id @default(autoincrement())
  userId    Int?
  user      User?    @relation("userAlerts", fields: [userId], references: [id], onDelete: Cascade)
  name      String
  type      String   // price_cross, price_change_pct, sentiment_shift, news_keyword, volume_spike
  symbol    String?
  condition String   // JSON: { threshold, direction, keyword, etc. }
  enabled   Boolean  @default(true)
  triggers  AlertTrigger[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([symbol])
  @@index([enabled])
  @@index([userId])
}

model AlertTrigger {
  id        Int      @id @default(autoincrement())
  alertId   Int
  alert     Alert    @relation(fields: [alertId], references: [id], onDelete: Cascade)
  message   String
  value     String?  // The value that triggered (e.g. price)
  createdAt DateTime @default(now())

  @@index([alertId])
}

model NewsCluster {
  id          Int      @id @default(autoincrement())
  title       String
  summary     String?
  impactScore Float    @default(0) // 1-10
  category    String?
  tickers     String?  // comma-separated
  articleCount Int     @default(0)
  avgSentiment Float?
  articles    NewsClusterArticle[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([impactScore])
  @@index([createdAt])
}

model NewsClusterArticle {
  id        Int      @id @default(autoincrement())
  clusterId Int
  cluster   NewsCluster @relation(fields: [clusterId], references: [id], onDelete: Cascade)
  articleId Int
  createdAt DateTime @default(now())

  @@unique([clusterId, articleId])
  @@index([articleId])
}

model InsiderTrade {
  id              Int      @id @default(autoincrement())
  symbol          String
  filingDate      DateTime
  tradeDate       DateTime
  ownerName       String
  ownerTitle      String?
  transactionType String   // P (Purchase), S (Sale)
  shares          Float
  pricePerShare   Float?
  totalValue      Float?
  sharesOwned     Float?
  secFilingUrl    String?
  createdAt       DateTime @default(now())

  @@index([symbol])
  @@index([filingDate])
  @@index([transactionType])
}

model SentimentArchive {
  id           Int      @id @default(autoincrement())
  date         DateTime
  scope        String   // ticker, category, market
  scopeValue   String   // e.g. "AAPL", "tech", "all"
  avgScore     Float
  articleCount Int
  bullishCount Int      @default(0)
  bearishCount Int      @default(0)
  neutralCount Int      @default(0)
  createdAt    DateTime @default(now())

  @@unique([date, scope, scopeValue])
  @@index([scope, scopeValue])
}

// ── Auth & Billing (v0.9.0) ──

model User {
  id                   Int           @id @default(autoincrement())
  email                String        @unique
  name                 String?
  avatarUrl            String?
  googleId             String?       @unique
  plan                 String        @default("free") // "free" | "pro"
  stripeCustomerId     String?       @unique
  stripeSubscriptionId String?
  planExpiresAt        DateTime?
  // Alpaca trading
  alpacaApiKey         String?
  alpacaSecretKey      String?
  alpacaPaper          Boolean       @default(true)
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  sessions             AuthSession[]
  alerts               Alert[]       @relation("userAlerts")
  userSessions         UserSession[] @relation("userSessions")
  trades               TradeOrder[]  @relation("userTrades")
}

model AuthSession {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
  @@index([token])
}

model VerificationCode {
  id        Int      @id @default(autoincrement())
  email     String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  @@index([email, code])
}
