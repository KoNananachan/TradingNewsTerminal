# === Core ===
DATABASE_URL="file:./prisma/prod.db"
PORT=3001
SCRAPE_INTERVAL_MINUTES=10

# === News Data Source ===
# URL to the news API endpoint. Leave empty to disable scraping.
# The API should return articles with analysis/recommendations.
NEWS_API_URL=""

# === AI / LLM Provider ===
# Any OpenAI-compatible API endpoint (OpenAI, Gemini, local Ollama, etc.)
AI_API_KEY=""
AI_BASE_URL="https://generativelanguage.googleapis.com/v1beta"
AI_MODEL="gemini-2.0-flash"

# === Google OAuth (optional) ===
GOOGLE_CLIENT_ID=""
VITE_GOOGLE_CLIENT_ID=""

# === WalletConnect (optional, for Web3 wallet connection) ===
VITE_WALLETCONNECT_PROJECT_ID=""

# === Email (Resend) ===
RESEND_API_KEY=""
RESEND_FROM_EMAIL="noreply@example.com"

# === Billing (Stripe, optional) ===
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_ID=""

# === Encryption (required for Alpaca credential storage) ===
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=""

# === CORS (production) ===
# Comma-separated list of allowed origins for production
ALLOWED_ORIGINS=""

# === GCS Backup (optional) ===
GCS_BUCKET=""
GCS_BACKUP_INTERVAL_MINUTES=5
